rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email is string
        && (
          request.auth.token.email.matches('(?i)^(admin@edencafe\\.com|phoo1236@gmail\\.com|sonsawan\\.1231@gmail\\.com)$')
          || (
            exists(/databases/$(database)/documents/admin_users/$(request.auth.uid))
            && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.status == 'active'
            && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role in ['owner', 'head_manager', 'manager']
          )
        );
    }
    function isOwner() {
      return isSignedIn()
        && (
          (request.auth.token.keys().hasAny(['role']) && request.auth.token.role == 'OWNER')
          || (request.auth.token.keys().hasAny(['is_owner']) && request.auth.token.is_owner == true)
          || (
            request.auth.token.email is string
            && request.auth.token.email.matches('(?i)^(admin@edencafe\\.com|phoo1236@gmail\\.com|sonsawan\\.1231@gmail\\.com)$')
          )
          || (
            exists(/databases/$(database)/documents/admin_users/$(request.auth.uid))
            && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.status == 'active'
            && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role == 'owner'
          )
        );
    }
    function isHeadManager() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid))
        && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.status == 'active'
        && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role == 'head_manager';
    }
    function isManager() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid))
        && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.status == 'active'
        && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role == 'manager';
    }
    function hasAdminPermission(permission) {
      return isOwner()
        || isHeadManager()
        || (
          isManager()
          && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.permissions[permission] == true
        );
    }
    function isShortString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }
    function isValidOptionalLoyaltyOrderFields() {
      return (!request.resource.data.keys().hasAny(['normalDiscount']) || (request.resource.data.normalDiscount is number && request.resource.data.normalDiscount >= 0 && request.resource.data.normalDiscount <= 1000000))
        && (!request.resource.data.keys().hasAny(['loyaltyDiscount']) || (request.resource.data.loyaltyDiscount is number && request.resource.data.loyaltyDiscount >= 0 && request.resource.data.loyaltyDiscount <= 1000000))
        && (!request.resource.data.keys().hasAny(['totalBeforeLoyalty']) || (request.resource.data.totalBeforeLoyalty is number && request.resource.data.totalBeforeLoyalty >= 0 && request.resource.data.totalBeforeLoyalty <= 1000000))
        && (!request.resource.data.keys().hasAny(['earnedPoints']) || (request.resource.data.earnedPoints is number && request.resource.data.earnedPoints >= 0 && request.resource.data.earnedPoints <= 1000000))
        && (!request.resource.data.keys().hasAny(['redeemedPoints']) || (request.resource.data.redeemedPoints is number && request.resource.data.redeemedPoints >= 0 && request.resource.data.redeemedPoints <= 1000000))
        && (!request.resource.data.keys().hasAny(['loyaltyRedemption']) || request.resource.data.loyaltyRedemption is map)
        && (!request.resource.data.keys().hasAny(['loyalty']) || request.resource.data.loyalty is map)
        && (!request.resource.data.keys().hasAny(['loyaltySyncStatus']) || request.resource.data.loyaltySyncStatus in ['skipped', 'pending', 'syncing', 'synced', 'failed', 'local'])
        && (!request.resource.data.keys().hasAny(['loyaltyError']) || (request.resource.data.loyaltyError is string && request.resource.data.loyaltyError.size() <= 500))
        && (!request.resource.data.keys().hasAny(['loyaltyIdempotencyKey']) || (request.resource.data.loyaltyIdempotencyKey is string && request.resource.data.loyaltyIdempotencyKey.size() <= 120))
        && (!request.resource.data.keys().hasAny(['loyaltySyncedAt']) || request.resource.data.loyaltySyncedAt is string || request.resource.data.loyaltySyncedAt is timestamp);
    }
    function isValidAdminOrderCreate() {
      return request.resource.data.keys().hasOnly([
          'id', 'date', 'businessDate', 'businessDateLabel', 'items', 'total', 'totalAmount', 'uid', 'timestamp',
           'customerName', 'phone', 'address', 'status',
           'source', 'orderType', 'receiptNo', 'paymentStatus', 'paymentMethod',
          'paymentLabel', 'customerUid', 'customerEmail', 'customerLineId',
          'customerTier', 'customerMemberCode', 'customerProfileSynced',
          'subtotal', 'discount', 'normalDiscount', 'loyaltyDiscount',
          'totalBeforeLoyalty', 'taxIncluded', 'paidAmount', 'changeAmount',
          'earnedPoints', 'redeemedPoints', 'loyaltyRedemption', 'loyalty',
          'loyaltySyncStatus', 'loyaltyError', 'loyaltyIdempotencyKey',
          'loyaltySyncedAt',
          'note', 'cashierUid', 'cashierName', 'cashierEmail',
          'isTestOrder', 'softLaunch', 'stockAdjusted', 'stockAdjustments',
          'stockMode', 'billStatus', 'isOpenBill', 'orderMode',
          'openedAt', 'paidAt', 'updatedAt', 'updatedBy',
          'closedAt', 'closedBy', 'closedByName', 'createdAt'
        ])
        && request.resource.data.keys().hasAll(['id', 'date', 'items', 'totalAmount', 'uid', 'timestamp', 'status'])
        && request.resource.data.uid == request.auth.uid
        && isShortString(request.resource.data.id, 60)
        && isShortString(request.resource.data.date, 60)
        && (!request.resource.data.keys().hasAny(['businessDate']) || (request.resource.data.businessDate is string && request.resource.data.businessDate.matches('^\\d{4}-\\d{2}-\\d{2}$')))
        && (!request.resource.data.keys().hasAny(['businessDateLabel']) || (request.resource.data.businessDateLabel is string && request.resource.data.businessDateLabel.size() <= 60))
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 100
        && request.resource.data.totalAmount is number
        && request.resource.data.totalAmount >= 0
        && request.resource.data.totalAmount <= 1000000
        && request.resource.data.status in ['pending', 'processing', 'completed', 'cancelled']
        && (!request.resource.data.keys().hasAny(['source']) || request.resource.data.source in ['pos', 'online'])
        && (!request.resource.data.keys().hasAny(['orderType']) || request.resource.data.orderType in ['pos', 'online', 'shop'])
        && (!request.resource.data.keys().hasAny(['paymentStatus']) || request.resource.data.paymentStatus in ['pending', 'paid', 'failed', 'refunded'])
        && (!request.resource.data.keys().hasAny(['paymentMethod']) || request.resource.data.paymentMethod in ['cash', 'transfer', 'thai_chuay_thai_plus', 'qr', 'card', 'other'])
        && (!request.resource.data.keys().hasAny(['paymentLabel']) || (request.resource.data.paymentLabel is string && request.resource.data.paymentLabel.size() <= 40))
        && (!request.resource.data.keys().hasAny(['receiptNo']) || isShortString(request.resource.data.receiptNo, 60))
        && (!request.resource.data.keys().hasAny(['customerName']) || (request.resource.data.customerName is string && request.resource.data.customerName.size() <= 120))
        && (!request.resource.data.keys().hasAny(['phone']) || (request.resource.data.phone is string && request.resource.data.phone.size() <= 40))
        && (!request.resource.data.keys().hasAny(['customerUid']) || (request.resource.data.customerUid is string && request.resource.data.customerUid.size() <= 120))
        && (!request.resource.data.keys().hasAny(['customerEmail']) || (request.resource.data.customerEmail is string && request.resource.data.customerEmail.size() <= 180))
        && (!request.resource.data.keys().hasAny(['customerLineId']) || (request.resource.data.customerLineId is string && request.resource.data.customerLineId.size() <= 80))
        && (!request.resource.data.keys().hasAny(['customerTier']) || (request.resource.data.customerTier is string && request.resource.data.customerTier.size() <= 30))
        && (!request.resource.data.keys().hasAny(['customerMemberCode']) || (request.resource.data.customerMemberCode is string && request.resource.data.customerMemberCode.size() <= 40))
        && (!request.resource.data.keys().hasAny(['customerProfileSynced']) || request.resource.data.customerProfileSynced is bool)
        && (!request.resource.data.keys().hasAny(['address']) || (request.resource.data.address is string && request.resource.data.address.size() <= 250))
        && (!request.resource.data.keys().hasAny(['note']) || (request.resource.data.note is string && request.resource.data.note.size() <= 500))
        && (!request.resource.data.keys().hasAny(['subtotal']) || (request.resource.data.subtotal is number && request.resource.data.subtotal >= 0 && request.resource.data.subtotal <= 1000000))
        && (!request.resource.data.keys().hasAny(['discount']) || (request.resource.data.discount is number && request.resource.data.discount >= 0 && request.resource.data.discount <= 1000000))
        && isValidOptionalLoyaltyOrderFields()
        && (!request.resource.data.keys().hasAny(['taxIncluded']) || (request.resource.data.taxIncluded is number && request.resource.data.taxIncluded >= 0 && request.resource.data.taxIncluded <= 1000000))
        && (!request.resource.data.keys().hasAny(['paidAmount']) || (request.resource.data.paidAmount is number && request.resource.data.paidAmount >= 0 && request.resource.data.paidAmount <= 1000000))
        && (!request.resource.data.keys().hasAny(['changeAmount']) || (request.resource.data.changeAmount is number && request.resource.data.changeAmount >= 0 && request.resource.data.changeAmount <= 1000000))
        && (!request.resource.data.keys().hasAny(['cashierUid']) || request.resource.data.cashierUid == request.auth.uid)
        && (!request.resource.data.keys().hasAny(['cashierName']) || (request.resource.data.cashierName is string && request.resource.data.cashierName.size() <= 120))
        && (!request.resource.data.keys().hasAny(['cashierEmail']) || (request.resource.data.cashierEmail is string && request.resource.data.cashierEmail.size() <= 180))
        && (!request.resource.data.keys().hasAny(['isTestOrder']) || request.resource.data.isTestOrder is bool)
        && (!request.resource.data.keys().hasAny(['softLaunch']) || request.resource.data.softLaunch is bool)
        && (!request.resource.data.keys().hasAny(['stockAdjusted']) || request.resource.data.stockAdjusted is bool)
        && (!request.resource.data.keys().hasAny(['stockAdjustments']) || (request.resource.data.stockAdjustments is list && request.resource.data.stockAdjustments.size() <= 100))
        && (!request.resource.data.keys().hasAny(['stockMode']) || (request.resource.data.stockMode is string && request.resource.data.stockMode.size() <= 40))
        && (!request.resource.data.keys().hasAny(['billStatus']) || request.resource.data.billStatus in ['open', 'paid', 'cancelled'])
        && (!request.resource.data.keys().hasAny(['isOpenBill']) || request.resource.data.isOpenBill is bool)
        && (!request.resource.data.keys().hasAny(['orderMode']) || request.resource.data.orderMode in ['pay_now', 'open_bill'])
        && (!request.resource.data.keys().hasAny(['openedAt']) || request.resource.data.openedAt == request.time)
        && (!request.resource.data.keys().hasAny(['paidAt']) || request.resource.data.paidAt == request.time)
        && (!request.resource.data.keys().hasAny(['updatedAt']) || request.resource.data.updatedAt == request.time)
        && (!request.resource.data.keys().hasAny(['updatedBy']) || request.resource.data.updatedBy == request.auth.uid)
        && (!request.resource.data.keys().hasAny(['closedAt']) || request.resource.data.closedAt == request.time)
        && (!request.resource.data.keys().hasAny(['closedBy']) || request.resource.data.closedBy == request.auth.uid)
        && (!request.resource.data.keys().hasAny(['closedByName']) || (request.resource.data.closedByName is string && request.resource.data.closedByName.size() <= 120))
        && request.resource.data.timestamp == request.time
        && (!request.resource.data.keys().hasAny(['createdAt']) || request.resource.data.createdAt == request.time);
    }
    function isValidPosOrderCreate() {
      return (hasAdminPermission('pos') || hasAdminPermission('orders'))
        && request.resource.data.keys().hasOnly([
          'id', 'date', 'businessDate', 'businessDateLabel', 'items', 'total', 'totalAmount', 'uid', 'timestamp',
          'customerName', 'phone', 'address', 'status',
          'source', 'orderType', 'receiptNo', 'paymentStatus', 'paymentMethod',
          'paymentLabel', 'customerUid', 'customerEmail', 'customerLineId',
          'customerTier', 'customerMemberCode', 'customerProfileSynced',
          'subtotal', 'discount', 'normalDiscount', 'loyaltyDiscount',
          'totalBeforeLoyalty', 'taxIncluded', 'paidAmount', 'changeAmount',
          'earnedPoints', 'redeemedPoints', 'loyaltyRedemption', 'loyalty',
          'loyaltySyncStatus', 'loyaltyError', 'loyaltyIdempotencyKey',
          'loyaltySyncedAt',
          'note', 'cashierUid', 'cashierName', 'cashierEmail',
          'isTestOrder', 'softLaunch', 'stockAdjusted', 'stockAdjustments',
          'stockMode', 'billStatus', 'isOpenBill', 'orderMode',
          'openedAt', 'paidAt', 'updatedAt', 'updatedBy',
          'closedAt', 'closedBy', 'closedByName', 'createdAt'
        ])
        && request.resource.data.keys().hasAll([
          'id', 'date', 'items', 'totalAmount', 'uid',
          'status', 'source', 'orderType'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.source == 'pos'
        && request.resource.data.orderType == 'pos'
        && isShortString(request.resource.data.id, 80)
        && isShortString(request.resource.data.date, 80)
        && (!request.resource.data.keys().hasAny(['businessDate']) || (request.resource.data.businessDate is string && request.resource.data.businessDate.matches('^\\d{4}-\\d{2}-\\d{2}$')))
        && (!request.resource.data.keys().hasAny(['businessDateLabel']) || (request.resource.data.businessDateLabel is string && request.resource.data.businessDateLabel.size() <= 60))
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 200
        && request.resource.data.totalAmount is number
        && request.resource.data.totalAmount >= 0
        && request.resource.data.totalAmount <= 1000000
        && request.resource.data.status in ['pending', 'processing', 'completed', 'cancelled']
        && (!request.resource.data.keys().hasAny(['paymentStatus']) || request.resource.data.paymentStatus in ['pending', 'paid', 'failed', 'refunded'])
        && (!request.resource.data.keys().hasAny(['paymentMethod']) || request.resource.data.paymentMethod in ['cash', 'transfer', 'thai_chuay_thai_plus', 'qr', 'card', 'other'])
        && (!request.resource.data.keys().hasAny(['paymentLabel']) || (request.resource.data.paymentLabel is string && request.resource.data.paymentLabel.size() <= 80))
        && (!request.resource.data.keys().hasAny(['receiptNo']) || (request.resource.data.receiptNo is string && request.resource.data.receiptNo.size() > 0 && request.resource.data.receiptNo.size() <= 80))
        && (!request.resource.data.keys().hasAny(['customerName']) || (request.resource.data.customerName is string && request.resource.data.customerName.size() <= 120))
        && (!request.resource.data.keys().hasAny(['phone']) || (request.resource.data.phone is string && request.resource.data.phone.size() <= 40))
        && (!request.resource.data.keys().hasAny(['address']) || (request.resource.data.address is string && request.resource.data.address.size() <= 250))
        && (!request.resource.data.keys().hasAny(['note']) || (request.resource.data.note is string && request.resource.data.note.size() <= 500))
        && (!request.resource.data.keys().hasAny(['customerUid']) || (request.resource.data.customerUid is string && request.resource.data.customerUid.size() <= 120))
        && (!request.resource.data.keys().hasAny(['customerEmail']) || (request.resource.data.customerEmail is string && request.resource.data.customerEmail.size() <= 180))
        && (!request.resource.data.keys().hasAny(['customerLineId']) || (request.resource.data.customerLineId is string && request.resource.data.customerLineId.size() <= 80))
        && (!request.resource.data.keys().hasAny(['customerTier']) || (request.resource.data.customerTier is string && request.resource.data.customerTier.size() <= 30))
        && (!request.resource.data.keys().hasAny(['customerMemberCode']) || (request.resource.data.customerMemberCode is string && request.resource.data.customerMemberCode.size() <= 40))
        && (!request.resource.data.keys().hasAny(['customerProfileSynced']) || request.resource.data.customerProfileSynced is bool)
        && (!request.resource.data.keys().hasAny(['subtotal']) || (request.resource.data.subtotal is number && request.resource.data.subtotal >= 0 && request.resource.data.subtotal <= 1000000))
        && (!request.resource.data.keys().hasAny(['discount']) || (request.resource.data.discount is number && request.resource.data.discount >= 0 && request.resource.data.discount <= 1000000))
        && isValidOptionalLoyaltyOrderFields()
        && (!request.resource.data.keys().hasAny(['taxIncluded']) || (request.resource.data.taxIncluded is number && request.resource.data.taxIncluded >= 0 && request.resource.data.taxIncluded <= 1000000))
        && (!request.resource.data.keys().hasAny(['paidAmount']) || (request.resource.data.paidAmount is number && request.resource.data.paidAmount >= 0 && request.resource.data.paidAmount <= 1000000))
        && (!request.resource.data.keys().hasAny(['changeAmount']) || (request.resource.data.changeAmount is number && request.resource.data.changeAmount >= 0 && request.resource.data.changeAmount <= 1000000))
        && (!request.resource.data.keys().hasAny(['total']) || (request.resource.data.total is number && request.resource.data.total >= 0 && request.resource.data.total <= 1000000))
        && (!request.resource.data.keys().hasAny(['cashierUid']) || request.resource.data.cashierUid == request.auth.uid)
        && (!request.resource.data.keys().hasAny(['cashierName']) || (request.resource.data.cashierName is string && request.resource.data.cashierName.size() <= 120))
        && (!request.resource.data.keys().hasAny(['cashierEmail']) || (request.resource.data.cashierEmail is string && request.resource.data.cashierEmail.size() <= 180))
        && (!request.resource.data.keys().hasAny(['isTestOrder']) || request.resource.data.isTestOrder is bool)
        && (!request.resource.data.keys().hasAny(['softLaunch']) || request.resource.data.softLaunch is bool)
        && (!request.resource.data.keys().hasAny(['stockAdjusted']) || request.resource.data.stockAdjusted is bool)
        && (!request.resource.data.keys().hasAny(['stockAdjustments']) || (request.resource.data.stockAdjustments is list && request.resource.data.stockAdjustments.size() <= 200))
        && (!request.resource.data.keys().hasAny(['stockMode']) || (request.resource.data.stockMode is string && request.resource.data.stockMode.size() <= 60))
        && (!request.resource.data.keys().hasAny(['billStatus']) || request.resource.data.billStatus in ['open', 'paid', 'cancelled'])
        && (!request.resource.data.keys().hasAny(['isOpenBill']) || request.resource.data.isOpenBill is bool)
        && (!request.resource.data.keys().hasAny(['orderMode']) || request.resource.data.orderMode in ['pay_now', 'open_bill'])
        && (!request.resource.data.keys().hasAny(['timestamp']) || request.resource.data.timestamp is timestamp)
        && (!request.resource.data.keys().hasAny(['createdAt']) || request.resource.data.createdAt is timestamp)
        && (!request.resource.data.keys().hasAny(['openedAt']) || request.resource.data.openedAt is timestamp)
        && (!request.resource.data.keys().hasAny(['paidAt']) || request.resource.data.paidAt is timestamp)
        && (!request.resource.data.keys().hasAny(['updatedAt']) || request.resource.data.updatedAt is timestamp)
        && (!request.resource.data.keys().hasAny(['updatedBy']) || request.resource.data.updatedBy == request.auth.uid)
        && (!request.resource.data.keys().hasAny(['closedAt']) || request.resource.data.closedAt is timestamp)
        && (!request.resource.data.keys().hasAny(['closedBy']) || request.resource.data.closedBy == request.auth.uid)
        && (!request.resource.data.keys().hasAny(['closedByName']) || (request.resource.data.closedByName is string && request.resource.data.closedByName.size() <= 120));
    }
    function isPosAdminOrderWrite() {
      return (hasAdminPermission('pos') || hasAdminPermission('orders'))
        && request.resource.data.source == 'pos'
        && request.resource.data.orderType == 'pos'
        && request.resource.data.keys().hasAll(['items', 'totalAmount', 'status'])
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 300
        && request.resource.data.totalAmount is number
        && request.resource.data.totalAmount >= 0
        && request.resource.data.totalAmount <= 1000000
        && request.resource.data.status in ['pending', 'processing', 'completed', 'cancelled']
        && (!request.resource.data.keys().hasAny(['uid']) || request.resource.data.uid is string)
        && (!request.resource.data.keys().hasAny(['paymentStatus']) || request.resource.data.paymentStatus in ['pending', 'paid', 'failed', 'refunded'])
        && (!request.resource.data.keys().hasAny(['paymentMethod']) || request.resource.data.paymentMethod in ['cash', 'transfer', 'thai_chuay_thai_plus', 'qr', 'card', 'other'])
        && (!request.resource.data.keys().hasAny(['billStatus']) || request.resource.data.billStatus in ['open', 'paid', 'cancelled'])
        && (!request.resource.data.keys().hasAny(['isOpenBill']) || request.resource.data.isOpenBill is bool)
        && (!request.resource.data.keys().hasAny(['subtotal']) || (request.resource.data.subtotal is number && request.resource.data.subtotal >= 0 && request.resource.data.subtotal <= 1000000))
        && (!request.resource.data.keys().hasAny(['discount']) || (request.resource.data.discount is number && request.resource.data.discount >= 0 && request.resource.data.discount <= 1000000))
        && (!request.resource.data.keys().hasAny(['taxIncluded']) || (request.resource.data.taxIncluded is number && request.resource.data.taxIncluded >= 0 && request.resource.data.taxIncluded <= 1000000))
        && (!request.resource.data.keys().hasAny(['paidAmount']) || (request.resource.data.paidAmount is number && request.resource.data.paidAmount >= 0 && request.resource.data.paidAmount <= 1000000))
        && (!request.resource.data.keys().hasAny(['changeAmount']) || (request.resource.data.changeAmount is number && request.resource.data.changeAmount >= 0 && request.resource.data.changeAmount <= 1000000))
        && (!request.resource.data.keys().hasAny(['total']) || (request.resource.data.total is number && request.resource.data.total >= 0 && request.resource.data.total <= 1000000))
        && (!request.resource.data.keys().hasAny(['cashierUid']) || request.resource.data.cashierUid == request.auth.uid)
        && (!request.resource.data.keys().hasAny(['updatedBy']) || request.resource.data.updatedBy == request.auth.uid)
        && (!request.resource.data.keys().hasAny(['closedBy']) || request.resource.data.closedBy == request.auth.uid);
    }
    function isValidPosProductStockUpdate() {
      return (hasAdminPermission('pos') || hasAdminPermission('orders'))
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'stock', 'variants', 'updatedAt', 'updatedBy', 'stockUpdatedAt', 'stockUpdatedBy'
        ])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['stock'])
          || (request.resource.data.stock is number && request.resource.data.stock >= 0 && request.resource.data.stock <= 1000000))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['variants'])
          || (request.resource.data.variants is list && request.resource.data.variants.size() <= 200))
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['updatedAt'])
          || request.resource.data.updatedAt == request.time)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['stockUpdatedAt'])
          || request.resource.data.stockUpdatedAt == request.time)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['updatedBy'])
          || request.resource.data.updatedBy == request.auth.uid)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['stockUpdatedBy'])
          || request.resource.data.stockUpdatedBy == request.auth.uid);
    }
    function isValidPosOrderVoidUpdate() {
      return (hasAdminPermission('pos') || hasAdminPermission('orders'))
        && resource.data.source == 'pos'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'paymentStatus', 'voidReason', 'voidedAt', 'voidedBy',
          'voidedByName', 'voidedByEmail', 'voidedStockRestored',
          'stockRestoreAdjustments', 'updatedAt'
        ])
        && request.resource.data.status == 'cancelled'
        && (!request.resource.data.keys().hasAny(['paymentStatus']) || request.resource.data.paymentStatus == 'refunded')
        && (!request.resource.data.keys().hasAny(['voidReason']) || (request.resource.data.voidReason is string && request.resource.data.voidReason.size() <= 300))
        && (!request.resource.data.keys().hasAny(['voidedAt']) || request.resource.data.voidedAt == request.time)
        && (!request.resource.data.keys().hasAny(['voidedBy']) || request.resource.data.voidedBy == request.auth.uid)
        && (!request.resource.data.keys().hasAny(['voidedByName']) || (request.resource.data.voidedByName is string && request.resource.data.voidedByName.size() <= 120))
        && (!request.resource.data.keys().hasAny(['voidedByEmail']) || (request.resource.data.voidedByEmail is string && request.resource.data.voidedByEmail.size() <= 180))
        && (!request.resource.data.keys().hasAny(['voidedStockRestored']) || request.resource.data.voidedStockRestored is bool)
        && (!request.resource.data.keys().hasAny(['stockRestoreAdjustments']) || (request.resource.data.stockRestoreAdjustments is list && request.resource.data.stockRestoreAdjustments.size() <= 100))
        && (!request.resource.data.keys().hasAny(['updatedAt']) || request.resource.data.updatedAt == request.time);
    }
    function isValidPosOpenBillUpdate() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return (hasAdminPermission('pos') || hasAdminPermission('orders'))
        && resource.data.source == 'pos'
        && request.resource.data.source == 'pos'
        && request.resource.data.orderType == 'pos'
        && request.resource.data.uid is string
        && affected.hasOnly([
          'id', 'date', 'businessDate', 'businessDateLabel', 'items', 'total', 'totalAmount', 'uid',
          'source', 'orderType',
          'customerName', 'phone', 'address', 'status',
          'receiptNo', 'paymentStatus', 'paymentMethod', 'paymentLabel',
          'customerUid', 'customerEmail', 'customerLineId',
          'customerTier', 'customerMemberCode', 'customerProfileSynced',
          'subtotal', 'discount', 'taxIncluded', 'paidAmount', 'changeAmount',
          'normalDiscount', 'loyaltyDiscount', 'totalBeforeLoyalty',
          'earnedPoints', 'redeemedPoints', 'loyaltyRedemption', 'loyalty',
          'loyaltySyncStatus', 'loyaltyError', 'loyaltyIdempotencyKey',
          'loyaltySyncedAt',
          'note', 'cashierUid', 'cashierName', 'cashierEmail',
          'isTestOrder', 'softLaunch', 'stockAdjusted', 'stockAdjustments',
          'stockMode', 'billStatus', 'isOpenBill', 'orderMode',
          'openedAt', 'paidAt', 'timestamp', 'createdAt',
          'updatedAt', 'updatedBy', 'closedAt', 'closedBy', 'closedByName'
        ])
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 150
        && request.resource.data.status in ['pending', 'processing', 'completed', 'cancelled']
        && request.resource.data.paymentStatus in ['pending', 'paid', 'failed', 'refunded']
        && (!request.resource.data.keys().hasAny(['billStatus']) || request.resource.data.billStatus in ['open', 'paid', 'cancelled'])
        && (!request.resource.data.keys().hasAny(['isOpenBill']) || request.resource.data.isOpenBill is bool)
        && (!request.resource.data.keys().hasAny(['orderMode']) || request.resource.data.orderMode in ['pay_now', 'open_bill'])
        && (!request.resource.data.keys().hasAny(['totalAmount']) || (request.resource.data.totalAmount is number && request.resource.data.totalAmount >= 0 && request.resource.data.totalAmount <= 1000000))
        && (!request.resource.data.keys().hasAny(['total']) || (request.resource.data.total is number && request.resource.data.total >= 0 && request.resource.data.total <= 1000000))
        && (!request.resource.data.keys().hasAny(['subtotal']) || (request.resource.data.subtotal is number && request.resource.data.subtotal >= 0 && request.resource.data.subtotal <= 1000000))
        && (!request.resource.data.keys().hasAny(['discount']) || (request.resource.data.discount is number && request.resource.data.discount >= 0 && request.resource.data.discount <= 1000000))
        && isValidOptionalLoyaltyOrderFields()
        && (!request.resource.data.keys().hasAny(['taxIncluded']) || (request.resource.data.taxIncluded is number && request.resource.data.taxIncluded >= 0 && request.resource.data.taxIncluded <= 1000000))
        && (!request.resource.data.keys().hasAny(['paidAmount']) || (request.resource.data.paidAmount is number && request.resource.data.paidAmount >= 0 && request.resource.data.paidAmount <= 1000000))
        && (!request.resource.data.keys().hasAny(['changeAmount']) || (request.resource.data.changeAmount is number && request.resource.data.changeAmount >= 0 && request.resource.data.changeAmount <= 1000000))
        && (!request.resource.data.keys().hasAny(['paymentMethod']) || request.resource.data.paymentMethod in ['cash', 'transfer', 'thai_chuay_thai_plus', 'qr', 'card', 'other'])
        && (!request.resource.data.keys().hasAny(['paymentLabel']) || (request.resource.data.paymentLabel is string && request.resource.data.paymentLabel.size() <= 60))
        && (!request.resource.data.keys().hasAny(['receiptNo']) || (request.resource.data.receiptNo is string && request.resource.data.receiptNo.size() > 0 && request.resource.data.receiptNo.size() <= 80))
        && (!request.resource.data.keys().hasAny(['businessDate']) || (request.resource.data.businessDate is string && request.resource.data.businessDate.matches('^\\d{4}-\\d{2}-\\d{2}$')))
        && (!request.resource.data.keys().hasAny(['businessDateLabel']) || (request.resource.data.businessDateLabel is string && request.resource.data.businessDateLabel.size() <= 60))
        && (!request.resource.data.keys().hasAny(['customerName']) || (request.resource.data.customerName is string && request.resource.data.customerName.size() <= 120))
        && (!request.resource.data.keys().hasAny(['phone']) || (request.resource.data.phone is string && request.resource.data.phone.size() <= 40))
        && (!request.resource.data.keys().hasAny(['address']) || (request.resource.data.address is string && request.resource.data.address.size() <= 250))
        && (!request.resource.data.keys().hasAny(['note']) || (request.resource.data.note is string && request.resource.data.note.size() <= 500))
        && (!request.resource.data.keys().hasAny(['customerUid']) || (request.resource.data.customerUid is string && request.resource.data.customerUid.size() <= 120))
        && (!request.resource.data.keys().hasAny(['customerEmail']) || (request.resource.data.customerEmail is string && request.resource.data.customerEmail.size() <= 180))
        && (!request.resource.data.keys().hasAny(['customerLineId']) || (request.resource.data.customerLineId is string && request.resource.data.customerLineId.size() <= 80))
        && (!request.resource.data.keys().hasAny(['customerTier']) || (request.resource.data.customerTier is string && request.resource.data.customerTier.size() <= 30))
        && (!request.resource.data.keys().hasAny(['customerMemberCode']) || (request.resource.data.customerMemberCode is string && request.resource.data.customerMemberCode.size() <= 40))
        && (!request.resource.data.keys().hasAny(['customerProfileSynced']) || request.resource.data.customerProfileSynced is bool)
        && (!request.resource.data.keys().hasAny(['cashierUid']) || request.resource.data.cashierUid is string)
        && (!request.resource.data.keys().hasAny(['cashierName']) || (request.resource.data.cashierName is string && request.resource.data.cashierName.size() <= 120))
        && (!request.resource.data.keys().hasAny(['cashierEmail']) || (request.resource.data.cashierEmail is string && request.resource.data.cashierEmail.size() <= 180))
        && (!request.resource.data.keys().hasAny(['isTestOrder']) || request.resource.data.isTestOrder is bool)
        && (!request.resource.data.keys().hasAny(['softLaunch']) || request.resource.data.softLaunch is bool)
        && (!request.resource.data.keys().hasAny(['stockAdjusted']) || request.resource.data.stockAdjusted is bool)
        && (!request.resource.data.keys().hasAny(['stockAdjustments']) || (request.resource.data.stockAdjustments is list && request.resource.data.stockAdjustments.size() <= 200))
        && (!request.resource.data.keys().hasAny(['stockMode']) || (request.resource.data.stockMode is string && request.resource.data.stockMode.size() <= 60))
        && (!affected.hasAny(['updatedAt']) || request.resource.data.updatedAt is timestamp)
        && (!affected.hasAny(['updatedBy']) || request.resource.data.updatedBy == request.auth.uid)
        && (!affected.hasAny(['openedAt']) || request.resource.data.openedAt is timestamp)
        && (!affected.hasAny(['paidAt']) || request.resource.data.paidAt is timestamp)
        && (!affected.hasAny(['timestamp']) || request.resource.data.timestamp is timestamp)
        && (!affected.hasAny(['createdAt']) || request.resource.data.createdAt is timestamp)
        && (!affected.hasAny(['closedAt']) || request.resource.data.closedAt is timestamp)
        && (!affected.hasAny(['closedBy']) || request.resource.data.closedBy == request.auth.uid)
        && (!request.resource.data.keys().hasAny(['closedByName']) || (request.resource.data.closedByName is string && request.resource.data.closedByName.size() <= 120));
    }
    function ownsResource() {
      return isSignedIn()
        && (
          (resource.data.keys().hasAny(['uid']) && resource.data.uid == request.auth.uid)
          || (resource.data.keys().hasAny(['customerUid']) && resource.data.customerUid == request.auth.uid)
          || (resource.data.keys().hasAny(['customer_uid']) && resource.data.customer_uid == request.auth.uid)
          || (resource.data.keys().hasAny(['member_id']) && resource.data.member_id == request.auth.uid)
          || (resource.data.keys().hasAny(['memberUid']) && resource.data.memberUid == request.auth.uid)
          || (resource.data.keys().hasAny(['userId']) && resource.data.userId == request.auth.uid)
          || (resource.data.keys().hasAny(['owner_id']) && resource.data.owner_id == request.auth.uid)
          || (resource.data.keys().hasAny(['recipient_id']) && resource.data.recipient_id == request.auth.uid)
        );
    }
    function isArcheryBooking() {
      return resource.data.keys().hasAny(['service_type'])
        && resource.data.service_type == 'ARCHERY';
    }
    function signedIn() {
      return isSignedIn();
    }
    function hasRole(role) {
      return isSignedIn()
        && (
          (role == 'OWNER' && isOwner())
          || (
            request.auth.token.keys().hasAny(['role'])
            && request.auth.token.role == role
          )
          || (
            role == 'MANAGER'
            && (isHeadManager() || isManager())
          )
        );
    }
    function hasAnyRole(roles) {
      return isSignedIn()
        && (
          ('OWNER' in roles && isOwner())
          || (
            request.auth.token.keys().hasAny(['role'])
            && request.auth.token.role in roles
          )
          || (
            'MANAGER' in roles
            && (isHeadManager() || isManager())
          )
        );
    }
    function hasBranch(branchId) {
      return isOwner()
        || (
          isSignedIn()
          && request.auth.token.keys().hasAny(['branch_ids'])
          && request.auth.token.branch_ids is list
          && branchId in request.auth.token.branch_ids
        );
    }
    function isStaff() {
      return isSignedIn()
        && (
          (request.auth.token.keys().hasAny(['is_staff']) && request.auth.token.is_staff == true)
          || hasAnyRole(['OWNER', 'MANAGER', 'ARCHERY_STAFF', 'CASHIER'])
          || isAdmin()
        );
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isCustomerOwner(memberId) {
      return isSignedIn() && memberId == request.auth.uid;
    }
    function isOwnDocument(userId) {
      return isSelf(userId);
    }
    function sameBranch() {
      return resource.data.keys().hasAny(['branch_id'])
        && request.resource.data.keys().hasAny(['branch_id'])
        && request.resource.data.branch_id == resource.data.branch_id;
    }
    function denyWrite() {
      return false;
    }
    function noDelete() {
      return false;
    }
    function immutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }
    function userProfileCreateFields() {
      return [
        'uid', 'displayName', 'email', 'photoURL', 'phone', 'phoneE164',
        'id', 'phone_number', 'phone_display', 'email_lower', 'display_name',
        'avatar_url', 'firstName', 'lastName', 'loginUsername',
        'phoneAuthEmail', 'shippingAddress', 'birthDate', 'allergies',
        'healthNote', 'lineId', 'authProviderIds', 'registrationSource',
        'marketingConsent', 'privacyConsent', 'phoneVerifiedAt',
        'passwordLoginEnabled', 'profileCompleted', 'onboardingCompletedAt',
        'created_at', 'updated_at', 'last_login_at', 'createdAt', 'updatedAt'
      ];
    }
    function safeUserProfileUpdateFields() {
      return [
        'displayName', 'photoURL', 'phone', 'phoneE164',
        'phone_number', 'phone_display', 'display_name', 'avatar_url',
        'firstName', 'lastName', 'loginUsername', 'phoneAuthEmail',
        'shippingAddress', 'birthDate', 'allergies', 'healthNote',
        'lineId', 'authProviderIds', 'registrationSource',
        'marketingConsent', 'privacyConsent', 'phoneVerifiedAt',
        'passwordLoginEnabled', 'profileCompleted', 'onboardingCompletedAt',
        'last_login_at', 'updated_at', 'lastLoginAt', 'updatedAt'
      ];
    }
    function backendOnlyUserFields() {
      return [
        'role', 'is_staff', 'is_owner', 'branch_ids', 'branch_roles',
        'primary_branch_id', 'token_version', 'permissions', 'staff_status',
        'member_level', 'memberCode', 'tier', 'points', 'totalSpent',
        'visitCount', 'orderCount', 'bookingCount', 'cartItemCount',
        'status', 'adminNote', 'adminTags', 'authDisabled',
        'emailVerified', 'emailVerifiedAt', 'authCreatedAt'
      ];
    }
    function onlySafeUserProfileUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(safeUserProfileUpdateFields())
        && immutableFieldsUnchanged(backendOnlyUserFields());
    }
    function onlySafeUserProfileCreate(userId) {
      return isOwnDocument(userId)
        && request.resource.data.keys().hasOnly(userProfileCreateFields())
        && request.resource.data.keys().hasAll(['uid'])
        && request.resource.data.uid == request.auth.uid;
    }
    function onlyNotificationReadUpdate() {
      return ownsResource()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read_at', 'dismissed_at'])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['read_at']) || request.resource.data.read_at is timestamp || request.resource.data.read_at == null)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['dismissed_at']) || request.resource.data.dismissed_at is timestamp || request.resource.data.dismissed_at == null);
    }
    function canReadStaffBranch(branchId) {
      return isStaff()
        && hasAnyRole(['OWNER', 'MANAGER', 'ARCHERY_STAFF', 'CASHIER'])
        && hasBranch(branchId);
    }
    function canReadOwnerManagerBranch(branchId) {
      return hasAnyRole(['OWNER', 'MANAGER']) && hasBranch(branchId);
    }
    function canReadOwnerManagerCashierBranch(branchId) {
      return hasAnyRole(['OWNER', 'MANAGER', 'CASHIER']) && hasBranch(branchId);
    }
    function canReadResourceBranchAsStaff() {
      return isOwner()
        || (
          resource.data.keys().hasAny(['branch_id'])
          && canReadStaffBranch(resource.data.branch_id)
        );
    }
    function canReadResourceBranchAsOwnerManager() {
      return isOwner()
        || (
          resource.data.keys().hasAny(['branch_id'])
          && canReadOwnerManagerBranch(resource.data.branch_id)
        );
    }
    function canReadResourceBranchAsOwnerManagerCashier() {
      return isOwner()
        || (
          resource.data.keys().hasAny(['branch_id'])
          && canReadOwnerManagerCashierBranch(resource.data.branch_id)
        );
    }
    function canReadWebPaymentBranch(branchId) {
      return hasAnyRole(['OWNER', 'MANAGER', 'ARCHERY_STAFF']) && hasBranch(branchId);
    }
    function canReadResourceBranchAsWebPaymentStaff() {
      return isOwner()
        || (
          resource.data.keys().hasAny(['branch_id'])
          && canReadWebPaymentBranch(resource.data.branch_id)
        );
    }
    function paymentSensitiveOrderFields() {
      return [
        'paymentStatus', 'payment_status', 'payment_id', 'payment_provider',
        'payment_env', 'payment_environment', 'provider_ref', 'paidAt', 'paid_at',
        'payment_updated_at', 'receipt_id', 'refund_id', 'refund_request_id'
      ];
    }
    function isAdminOrderNonPaymentUpdate() {
      return hasAdminPermission('orders')
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(paymentSensitiveOrderFields());
    }

    // Publicly readable collections (content)
    match /shop_products/{docId} {
      allow read: if true;
      allow write: if hasAdminPermission('shop');
    }
    match /shop_categories/{docId} {
      allow read: if true;
      allow write: if hasAdminPermission('shop');
    }
    match /tables/{docId} {
      allow read: if true;
      allow write: if hasAdminPermission('tables');
    }
    match /rooms/{docId} {
      allow read: if true;
      allow write: if hasAdminPermission('rooms');
    }
    match /blogs/{docId} {
      allow read: if true;
      allow write: if hasAdminPermission('blogs');
    }
    match /faqs/{docId} {
      allow read: if true;
      allow write: if hasAdminPermission('faqs');
    }
    match /site_settings/{docId} {
      allow read: if true;
      allow write: if (docId == 'footer' && hasAdminPermission('footer'))
        || (docId == 'index' && hasAdminPermission('index'))
        || (docId == 'promptpay' && hasAdminPermission('promptpay'))
        || (docId == 'marketing' && hasAdminPermission('marketing'))
        || (docId == 'loyalty' && hasAdminPermission('loyalty'))
        || (docId == 'archery' && hasAdminPermission('bookings'));
    }
    match /categories/{docId} {
      allow read: if true;
      allow write: if hasAdminPermission('products');
    }
    match /products/{docId} {
      allow read: if true;
      allow create, delete: if hasAdminPermission('products');
      allow update: if hasAdminPermission('products') || isValidPosProductStockUpdate();
    }
    match /pos_discounts/{docId} {
      allow read: if true;
      allow create, update: if hasAdminPermission('discounts')
        && request.resource.data.keys().hasOnly([
          'id', 'label', 'type', 'value', 'active', 'order',
          'createdAt', 'updatedAt', 'createdBy', 'updatedBy'
        ])
        && (!request.resource.data.keys().hasAny(['id']) || request.resource.data.id is string)
        && request.resource.data.label is string
        && request.resource.data.label.size() > 0
        && request.resource.data.label.size() <= 80
        && request.resource.data.type in ['percent', 'amount']
        && request.resource.data.value is number
        && request.resource.data.value > 0
        && request.resource.data.value <= 100000
        && request.resource.data.active is bool
        && request.resource.data.order is number
        && (!request.resource.data.keys().hasAny(['createdAt']) || request.resource.data.createdAt is timestamp)
        && (!request.resource.data.keys().hasAny(['updatedAt']) || request.resource.data.updatedAt is timestamp)
        && (!request.resource.data.keys().hasAny(['createdBy']) || request.resource.data.createdBy == request.auth.uid)
        && (!request.resource.data.keys().hasAny(['updatedBy']) || request.resource.data.updatedBy == request.auth.uid);
      allow delete: if hasAdminPermission('discounts');
    }
    match /point_ledger/{docId} {
      allow read: if hasAdminPermission('loyalty')
        || hasAdminPermission('members')
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update, delete: if denyWrite();
    }
    match /member_summaries/{userId} {
      allow read: if isOwnDocument(userId)
        || (resource.data.keys().hasAny(['member_id']) && isCustomerOwner(resource.data.member_id))
        || canReadResourceBranchAsOwnerManagerCashier();
      allow create, update, delete: if denyWrite();
    }
    match /google_reviews/{docId} {
      allow read: if true;
      allow write: if isOwner();
    }
    match /pos_apk_releases/{releaseId} {
      allow read: if hasAdminPermission('pos');
      allow create, update: if hasAdminPermission('pos')
        && request.resource.data.keys().hasOnly([
          'appId', 'versionName', 'versionCode', 'channel', 'status',
          'sha256', 'size', 'storagePath', 'functionAsset', 'assetReference',
          'releaseNotes', 'minSupportedVersionCode', 'forceUpdate',
          'createdBy', 'createdAt', 'updatedBy', 'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'appId', 'versionName', 'versionCode', 'channel', 'status', 'sha256'
        ])
        && request.resource.data.appId == 'com.personal.pos'
        && request.resource.data.versionName is string
        && request.resource.data.versionName.size() > 0
        && request.resource.data.versionName.size() <= 40
        && request.resource.data.versionCode is number
        && request.resource.data.versionCode > 0
        && request.resource.data.versionCode <= 1000000
        && request.resource.data.channel in ['test', 'pilot', 'production']
        && request.resource.data.status in ['draft', 'active', 'revoked']
        && request.resource.data.sha256 is string
        && request.resource.data.sha256.matches('(?i)^[a-f0-9]{64}$')
        && (!request.resource.data.keys().hasAny(['size']) || (request.resource.data.size is number && request.resource.data.size >= 0))
        && (!request.resource.data.keys().hasAny(['storagePath']) || (request.resource.data.storagePath is string && request.resource.data.storagePath.size() <= 300))
        && (!request.resource.data.keys().hasAny(['functionAsset']) || (request.resource.data.functionAsset is string && request.resource.data.functionAsset.size() <= 180))
        && (!request.resource.data.keys().hasAny(['assetReference']) || (request.resource.data.assetReference is string && request.resource.data.assetReference.size() <= 180))
        && (!request.resource.data.keys().hasAny(['releaseNotes']) || (request.resource.data.releaseNotes is string && request.resource.data.releaseNotes.size() <= 4000))
        && (!request.resource.data.keys().hasAny(['minSupportedVersionCode']) || (request.resource.data.minSupportedVersionCode is number && request.resource.data.minSupportedVersionCode >= 0))
        && (!request.resource.data.keys().hasAny(['forceUpdate']) || request.resource.data.forceUpdate is bool);
      allow delete: if isOwner();
    }
    match /pos_update_events/{eventId} {
      allow read: if hasAdminPermission('pos');
      allow write: if false;
    }
    match /pos_devices/{deviceId} {
      allow read: if hasAdminPermission('pos');
      allow write: if false;
    }
    match /admin_users/{userId} {
      allow read: if isOwner()
        || (
          isSignedIn()
          && request.auth.uid == userId
          && resource.data.status == 'active'
        );
      allow create, update: if isOwner()
        && request.resource.data.keys().hasOnly([
          'uid', 'email', 'displayName', 'role', 'status', 'permissions',
          'createdAt', 'updatedAt', 'createdBy', 'updatedBy'
        ])
        && request.resource.data.uid == userId
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() <= 180
        && request.resource.data.role in ['owner', 'head_manager', 'manager', 'staff']
        && request.resource.data.status in ['active', 'paused']
        && request.resource.data.permissions is map;
      allow delete: if isOwner() && request.auth.uid != userId;
    }
    match /users/{userId} {
      allow read: if isOwner()
        || isOwnDocument(userId)
        || (
          isStaff()
          && resource.data.keys().hasAny(['branch_ids'])
          && request.auth.token.keys().hasAny(['branch_ids'])
          && request.auth.token.branch_ids.hasAny(resource.data.branch_ids)
        )
        || (
          isStaff()
          && resource.data.keys().hasAny(['primary_branch_id'])
          && hasBranch(resource.data.primary_branch_id)
        );
      allow create: if onlySafeUserProfileCreate(userId);
      allow update: if isOwnDocument(userId)
        && onlySafeUserProfileUpdate();
      allow delete: if noDelete();
    }
    match /user_credentials/{userId} {
      allow read, write: if false;
    }
    match /email_verification_codes/{docId} {
      allow read, write: if false;
    }
    match /otp_verifications/{docId} {
      allow read, write: if false;
    }
    match /phone_number_index/{docId} {
      allow read, write: if false;
    }

    // User data (orders, bookings)
    match /orders/{docId} {
      allow create: if isPosAdminOrderWrite()
        || isValidPosOrderCreate()
        || ((hasAdminPermission('orders') || hasAdminPermission('pos')) && isValidAdminOrderCreate())
        || (isSignedIn()
        && request.resource.data.keys().hasOnly([
          'id', 'date', 'items', 'total', 'totalAmount', 'uid', 'timestamp',
          'customerName', 'phone', 'address', 'status',
          'source', 'orderType', 'paymentStatus', 'paymentMethod', 'paymentLabel',
          'fulfillmentMethod', 'shippingFee', 'subtotal', 'discount'
        ])
        && request.resource.data.keys().hasAll(['id', 'date', 'items', 'uid', 'timestamp'])
        && request.resource.data.uid == request.auth.uid
        && isShortString(request.resource.data.id, 40)
        && isShortString(request.resource.data.date, 40)
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 50
        && (!request.resource.data.keys().hasAny(['status']) || request.resource.data.status == 'pending')
        && (!request.resource.data.keys().hasAny(['source']) || request.resource.data.source == 'online')
        && (!request.resource.data.keys().hasAny(['orderType']) || request.resource.data.orderType in ['online', 'shop'])
        && (!request.resource.data.keys().hasAny(['paymentStatus']) || request.resource.data.paymentStatus == 'pending')
        && (!request.resource.data.keys().hasAny(['paymentMethod']) || request.resource.data.paymentMethod in ['cash', 'transfer', 'thai_chuay_thai_plus', 'qr', 'card', 'other'])
        && (!request.resource.data.keys().hasAny(['paymentLabel']) || (request.resource.data.paymentLabel is string && request.resource.data.paymentLabel.size() <= 80))
        && (!request.resource.data.keys().hasAny(['fulfillmentMethod']) || request.resource.data.fulfillmentMethod in ['delivery', 'pickup'])
        && (!request.resource.data.keys().hasAny(['shippingFee']) || (request.resource.data.shippingFee is number && request.resource.data.shippingFee >= 0 && request.resource.data.shippingFee <= 100000))
        && (!request.resource.data.keys().hasAny(['subtotal']) || (request.resource.data.subtotal is number && request.resource.data.subtotal >= 0 && request.resource.data.subtotal <= 1000000))
        && (!request.resource.data.keys().hasAny(['discount']) || (request.resource.data.discount is number && request.resource.data.discount >= 0 && request.resource.data.discount <= 1000000))
        && (!request.resource.data.keys().hasAny(['total']) || (request.resource.data.total is number && request.resource.data.total >= 0 && request.resource.data.total <= 1000000))
        && (!request.resource.data.keys().hasAny(['totalAmount']) || (request.resource.data.totalAmount is number && request.resource.data.totalAmount >= 0 && request.resource.data.totalAmount <= 1000000))
        && request.resource.data.timestamp == request.time);
      allow read: if hasAdminPermission('orders') || hasAdminPermission('pos') || ownsResource();
      allow update: if isAdminOrderNonPaymentUpdate() || isPosAdminOrderWrite() || isValidPosOrderVoidUpdate() || isValidPosOpenBillUpdate();
      allow delete: if hasAdminPermission('orders');
    }
    match /bookings/{docId} {
      allow read: if ownsResource() || canReadResourceBranchAsStaff();
      allow create, update, delete: if denyWrite();
    }
    match /booking_items/{docId} {
      allow read: if ownsResource() || canReadResourceBranchAsStaff();
      allow create, update, delete: if denyWrite();
    }
    match /resource_types/{docId} {
      allow read: if canReadResourceBranchAsStaff();
      allow create, update, delete: if denyWrite();
    }
    match /resources/{docId} {
      allow read: if canReadResourceBranchAsStaff();
      allow create, update, delete: if denyWrite();
    }
    match /resource_locks/{docId} {
      allow read: if canReadResourceBranchAsStaff();
      allow create, update, delete: if denyWrite();
    }
    match /lane_sessions/{docId} {
      allow read: if canReadResourceBranchAsStaff();
      allow create, update, delete: if denyWrite();
    }
    match /payments/{docId} {
      allow read: if ownsResource() || canReadResourceBranchAsOwnerManagerCashier();
      allow create, update, delete: if denyWrite();
    }
    match /payment_items/{docId} {
      allow read: if ownsResource() || canReadResourceBranchAsWebPaymentStaff();
      allow create, update, delete: if denyWrite();
    }
    match /payment_webhook_events/{docId} {
      allow read: if canReadResourceBranchAsOwnerManager();
      allow create, update, delete: if denyWrite();
    }
    match /payment_reconciliation_queue/{docId} {
      allow read: if canReadResourceBranchAsOwnerManager();
      allow create, update, delete: if denyWrite();
    }
    match /refund_requests/{docId} {
      allow read: if ownsResource() || canReadResourceBranchAsWebPaymentStaff();
      allow create, update, delete: if denyWrite();
    }
    match /refunds/{docId} {
      allow read: if ownsResource() || canReadResourceBranchAsWebPaymentStaff();
      allow create, update, delete: if denyWrite();
    }
    match /receipts/{docId} {
      allow read: if ownsResource() || canReadResourceBranchAsWebPaymentStaff();
      allow create, update, delete: if denyWrite();
    }
    match /reward_points/{docId} {
      allow read: if ownsResource() || canReadResourceBranchAsOwnerManager();
      allow create, update, delete: if denyWrite();
    }
    match /audit_logs/{docId} {
      allow read: if canReadResourceBranchAsOwnerManager();
      allow create, update, delete: if denyWrite();
    }
    match /staff_sessions/{docId} {
      allow read: if (
          isStaff()
          && resource.data.keys().hasAny(['staff_id'])
          && resource.data.staff_id == request.auth.uid
        )
        || canReadResourceBranchAsOwnerManager();
      allow create, update, delete: if denyWrite();
    }
    match /pos_orders/{docId} {
      allow read: if ownsResource() || canReadResourceBranchAsStaff();
      allow create, update, delete: if denyWrite();
    }
    match /pos_order_items/{docId} {
      allow read: if ownsResource() || canReadResourceBranchAsStaff();
      allow create, update, delete: if denyWrite();
    }
    match /payment_allocations/{docId} {
      allow read: if ownsResource() || canReadResourceBranchAsOwnerManagerCashier();
      allow create, update, delete: if denyWrite();
    }
    match /notifications/{docId} {
      allow read: if ownsResource() || canReadResourceBranchAsOwnerManager();
      allow create: if denyWrite();
      allow update: if onlyNotificationReadUpdate();
      allow delete: if noDelete();
    }
    match /notification_templates/{docId} {
      allow read: if canReadResourceBranchAsOwnerManager();
      allow create, update, delete: if denyWrite();
    }
    match /uploads/{docId} {
      allow read: if ownsResource() || canReadResourceBranchAsStaff();
      allow create, update, delete: if denyWrite();
    }
    match /idempotency_keys/{docId} {
      allow read, write: if false;
    }
    match /system_configs/{docId} {
      allow read: if isOwner()
        || (
          hasRole('MANAGER')
          && (
            !resource.data.keys().hasAny(['branch_id'])
            || hasBranch(resource.data.branch_id)
          )
        );
      allow create, update, delete: if denyWrite();
    }
    match /table_availability/{docId} {
      allow read: if true;
      allow write: if hasAdminPermission('tables');
    }
    match /stats/pageViews {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
